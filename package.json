{
  "name": "agent-code-gui",
  "version": "1.7.0",
  "description": "AgentCodeGUI — Claude Code 데스크탑 IDE (자체 파일 탐색기 + LSP 코드 인텔리전스)",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "author": "AgentCodeGUI",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:watch": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "gen-icon": "node scripts/gen-icon.cjs && node scripts/gen-installer-art.cjs",
    "package": "npm run gen-icon && electron-vite build && electron-builder --publish never",
    "release": "npm run gen-icon && electron-vite build && electron-builder --publish always",
    "postinstall": "node scripts/fetch-electron.cjs"
  },
  "build": {
    "appId": "com.agentcodegui.app",
    "productName": "AgentCodeGUI",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AgentCodeGUI",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "UnrealFactory",
        "repo": "AgentCodeGUI",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "pyright": "^1.1.410",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.5"
  }
}
